# Environment variables — copy relevant lines to .env.local (dev) or set in
# Vercel project settings (production). Static GitHub Pages builds need none
# of these except STATIC_EXPORT (set in deploy.yml).

# ── Build mode ────────────────────────────────────────────────────────────────
# Set ONLY for GitHub Pages static builds. Never set on Vercel.
# STATIC_EXPORT=true

# ── Dev server ────────────────────────────────────────────────────────────────
# PORT=3002

# ── Compose: local filesystem mode (dev default) ─────────────────────────────
# Sibling checkout of the product repo; defaults to ../piper-morgan-product
# PIPER_PRODUCT_ROOT=/path/to/piper-morgan-product

# ── Compose: GitHub API mode (Vercel; optional in dev) ───────────────────────
# Fine-grained PAT scoped to the product repo, Contents: Read and write.
# When set, drafts read/save via the GitHub Contents API instead of the
# local filesystem, and every save is a commit to GITHUB_DRAFT_BRANCH.
# GITHUB_DRAFT_TOKEN=github_pat_...
# GITHUB_DRAFT_OWNER=mediajunkie
# GITHUB_DRAFT_REPO=piper-morgan-product
# GITHUB_DRAFT_BRANCH=main

# ── Admin auth (required in production — APIs fail closed without them) ──────
# Generate:
#   ADMIN_SESSION_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   ADMIN_PASSWORD_HASH:  node -e "require('bcryptjs').hash(process.argv[1], 12).then(h => console.log(h))" 'your-password'
# ADMIN_SESSION_SECRET=
# ADMIN_PASSWORD_HASH=

# ── Analytics / monitoring ────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=          # if set on Vercel, add the ingest host to CSP connect-src
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=               # enables source-map upload at build time
